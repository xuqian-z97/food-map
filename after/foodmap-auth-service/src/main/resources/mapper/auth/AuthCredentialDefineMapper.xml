<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodmap.auth.infrastructure.persistence.mapper.AuthCredentialDefineMapper">
    <resultMap id="AuthCredentialResultMap" type="com.foodmap.auth.infrastructure.persistence.entity.AuthCredentialEntity">
        <id property="id" column="id"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
        <result property="isDelete" column="is_delete"/>
        <result property="credentialId" column="credential_id"/>
        <result property="accountId" column="account_id"/>
        <result property="credentialType" column="credential_type"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="hashAlgorithm" column="hash_algorithm"/>
    </resultMap>

    <select id="findByAccountIdAndCredentialType" resultMap="AuthCredentialResultMap">
        select id, created_time, updated_time, is_delete, credential_id, account_id,
               credential_type, password_hash, hash_algorithm
        from auth_credentials
        where account_id = #{accountId}
          and credential_type = #{credentialType}
          and is_delete = 0
        limit 1
    </select>

    <update id="updateByAccountIdAndCredentialType" parameterType="com.foodmap.auth.infrastructure.persistence.entity.AuthCredentialEntity">
        update auth_credentials
        set password_hash = #{passwordHash},
            hash_algorithm = #{hashAlgorithm},
            updated_time = #{updatedTime},
            is_delete = #{isDelete}
        where account_id = #{accountId}
          and credential_type = #{credentialType}
    </update>
</mapper>
