<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodmap.auth.infrastructure.persistence.mapper.AuthAccountDefineMapper">
    <resultMap id="AuthAccountResultMap" type="com.foodmap.auth.infrastructure.persistence.entity.AuthAccountEntity">
        <id property="id" column="id"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
        <result property="isDelete" column="is_delete"/>
        <result property="accountId" column="account_id"/>
        <result property="userId" column="user_id"/>
        <result property="accountName" column="account_name"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="accountStatus" column="account_status"/>
        <result property="registeredChannel" column="registered_channel"/>
        <result property="lastLoginTime" column="last_login_time"/>
    </resultMap>

    <select id="findByLoginIdentifier" resultMap="AuthAccountResultMap">
        select id, created_time, updated_time, is_delete, account_id, user_id, account_name,
               phone, email, account_status, registered_channel, last_login_time
        from auth_accounts
        where is_delete = 0
          and (lower(account_name) = #{normalized}
               or phone = #{original}
               or lower(email) = #{normalized})
        limit 1
    </select>
</mapper>
