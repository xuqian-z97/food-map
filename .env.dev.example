# FoodMap local isolated development environment.
# Copy this file to .env.dev before running Docker Compose.

FOODMAP_PROFILE=orbstack

# Image tags can be pinned here when the local stack becomes stable.
POSTGRES_IMAGE=postgis/postgis:16-3.4
REDIS_IMAGE=redis:7.2-alpine
NACOS_IMAGE=nacos/nacos-server:v2.4.3
RABBITMQ_IMAGE=rabbitmq:3.13-management-alpine
MINIO_IMAGE=minio/minio:latest

# Host ports.
POSTGRES_PORT=5432
REDIS_PORT=6379
NACOS_HTTP_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_RAFT_PORT=9849
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Development-only credentials.
POSTGRES_USER=foodmap
POSTGRES_PASSWORD=foodmap_dev_pwd
POSTGRES_DB=foodmap_platform
RABBITMQ_DEFAULT_USER=foodmap
RABBITMQ_DEFAULT_PASS=foodmap_dev_pwd
MINIO_ROOT_USER=foodmap
MINIO_ROOT_PASSWORD=foodmap_dev_pwd

# Values for future app containers in the same Compose network.
NACOS_SERVER_ADDR=nacos:8848
REDIS_HOST=redis
REDIS_PORT_IN_CONTAINER=6379
POSTGRES_HOST=postgres
POSTGRES_PORT_IN_CONTAINER=5432
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT_IN_CONTAINER=5672
MINIO_ENDPOINT=http://minio:9000
