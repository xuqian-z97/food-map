# FoodMap ECS2 deployment environment example

# Common
FOODMAP_ENV=prod
FOODMAP_PROFILE=prod
SPRING_PROFILES_ACTIVE=prod
TZ=Asia/Shanghai

# Ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
GATEWAY_PORT=8080
NACOS_PORT=8848
POSTGRES_PORT=5432
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# PostgreSQL
POSTGRES_USER=foodmap
POSTGRES_PASSWORD=change-me
POSTGRES_DB=foodmap_bootstrap

# Logical service databases
FOODMAP_AUTH_DB=foodmap_auth_db
FOODMAP_USER_DB=foodmap_user_db
FOODMAP_RELATION_DB=foodmap_relation_db
FOODMAP_STORE_DB=foodmap_store_db
FOODMAP_RECOMMENDATION_DB=foodmap_recommendation_db
FOODMAP_COMMUNITY_DB=foodmap_community_db
FOODMAP_MEDIA_DB=foodmap_media_db
AUTH_DB_URL=jdbc:postgresql://postgres:5432/foodmap_auth_db
USER_DB_URL=jdbc:postgresql://postgres:5432/foodmap_user_db
RELATION_DB_URL=jdbc:postgresql://postgres:5432/foodmap_relation_db
STORE_DB_URL=jdbc:postgresql://postgres:5432/foodmap_store_db
RECOMMENDATION_DB_URL=jdbc:postgresql://postgres:5432/foodmap_recommendation_db
COMMUNITY_DB_URL=jdbc:postgresql://postgres:5432/foodmap_community_db
MEDIA_DB_URL=jdbc:postgresql://postgres:5432/foodmap_media_db
AUTH_DB_USERNAME=foodmap
USER_DB_USERNAME=foodmap
RELATION_DB_USERNAME=foodmap
STORE_DB_USERNAME=foodmap
RECOMMENDATION_DB_USERNAME=foodmap
COMMUNITY_DB_USERNAME=foodmap
MEDIA_DB_USERNAME=foodmap
AUTH_DB_PASSWORD=change-me
USER_DB_PASSWORD=change-me
RELATION_DB_PASSWORD=change-me
STORE_DB_PASSWORD=change-me
RECOMMENDATION_DB_PASSWORD=change-me
COMMUNITY_DB_PASSWORD=change-me
MEDIA_DB_PASSWORD=change-me
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_POOL_IDLE_TIMEOUT_MS=600000
DB_POOL_MAX_LIFETIME_MS=1800000
DB_POOL_LEAK_DETECTION_MS=60000

# Redis
REDIS_PASSWORD=change-me
FOODMAP_REDISSON_ENABLED=false
FOODMAP_REDISSON_ADDRESS=redis://redis:6379
FOODMAP_REDISSON_PASSWORD=${REDIS_PASSWORD}
FOODMAP_REDISSON_DATABASE=0
FOODMAP_REDISSON_POOL_SIZE=8
FOODMAP_REDISSON_MIN_IDLE=1
FOODMAP_REDISSON_CONNECT_TIMEOUT_MS=3000
FOODMAP_REDISSON_TIMEOUT_MS=2000
FOODMAP_REDISSON_RETRY_ATTEMPTS=2
FOODMAP_REDISSON_RETRY_INTERVAL_MS=500

# RabbitMQ
RABBITMQ_DEFAULT_USER=foodmap
RABBITMQ_DEFAULT_PASS=change-me

# Nacos
NACOS_SERVER_ADDR=nacos:8848
NACOS_AUTH_ENABLE=true
NACOS_AUTH_TOKEN=change-me-at-least-32-chars
NACOS_AUTH_IDENTITY_KEY=foodmap
NACOS_AUTH_IDENTITY_VALUE=change-me

# JWT
JWT_SECRET=change-me-at-least-32-chars
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

# Aliyun OSS
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=foodmap-bucket
ALIYUN_OSS_ACCESS_KEY_ID=change-me
ALIYUN_OSS_ACCESS_KEY_SECRET=change-me

# Java memory
JAVA_OPTS=-Xms128m -Xmx256m -XX:+UseContainerSupport
