# FoodMap ECS2 deployment environment example

# Common
FOODMAP_ENV=prod
FOODMAP_PROFILE=prod
SPRING_PROFILES_ACTIVE=prod
TZ=Asia/Shanghai

# Ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
GATEWAY_PORT=8080
NACOS_PORT=8848
POSTGRES_PORT=5432
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# PostgreSQL
POSTGRES_USER=foodmap
POSTGRES_PASSWORD=change-me
POSTGRES_DB=foodmap_bootstrap

# Logical service databases
FOODMAP_AUTH_DB=foodmap_auth_db
FOODMAP_USER_DB=foodmap_user_db
FOODMAP_RELATION_DB=foodmap_relation_db
FOODMAP_STORE_DB=foodmap_store_db
FOODMAP_RECOMMENDATION_DB=foodmap_recommendation_db
FOODMAP_COMMUNITY_DB=foodmap_community_db
FOODMAP_MEDIA_DB=foodmap_media_db
FOODMAP_LOG_DB=foodmap_log_db
AUTH_DB_URL=jdbc:postgresql://postgres:5432/foodmap_auth_db
USER_DB_URL=jdbc:postgresql://postgres:5432/foodmap_user_db
RELATION_DB_URL=jdbc:postgresql://postgres:5432/foodmap_relation_db
STORE_DB_URL=jdbc:postgresql://postgres:5432/foodmap_store_db
RECOMMENDATION_DB_URL=jdbc:postgresql://postgres:5432/foodmap_recommendation_db
COMMUNITY_DB_URL=jdbc:postgresql://postgres:5432/foodmap_community_db
MEDIA_DB_URL=jdbc:postgresql://postgres:5432/foodmap_media_db
ADMIN_DB_URL=jdbc:postgresql://postgres:5432/foodmap_admin_db
LOG_DB_URL=jdbc:postgresql://postgres:5432/foodmap_log_db
AUTH_DB_USERNAME=foodmap
USER_DB_USERNAME=foodmap
RELATION_DB_USERNAME=foodmap
STORE_DB_USERNAME=foodmap
RECOMMENDATION_DB_USERNAME=foodmap
COMMUNITY_DB_USERNAME=foodmap
MEDIA_DB_USERNAME=foodmap
LOG_DB_USERNAME=foodmap
AUTH_DB_PASSWORD=change-me
USER_DB_PASSWORD=change-me
RELATION_DB_PASSWORD=change-me
STORE_DB_PASSWORD=change-me
RECOMMENDATION_DB_PASSWORD=change-me
COMMUNITY_DB_PASSWORD=change-me
MEDIA_DB_PASSWORD=change-me
LOG_DB_PASSWORD=change-me
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_POOL_IDLE_TIMEOUT_MS=600000
DB_POOL_MAX_LIFETIME_MS=1800000
DB_POOL_LEAK_DETECTION_MS=60000

# Redis
REDIS_PASSWORD=change-me
FOODMAP_REDISSON_ENABLED=false
FOODMAP_REDISSON_ADDRESS=redis://redis:6379
FOODMAP_REDISSON_PASSWORD=${REDIS_PASSWORD}
FOODMAP_REDISSON_DATABASE=0
FOODMAP_REDISSON_POOL_SIZE=8
FOODMAP_REDISSON_MIN_IDLE=1
FOODMAP_REDISSON_CONNECT_TIMEOUT_MS=3000
FOODMAP_REDISSON_TIMEOUT_MS=2000
FOODMAP_REDISSON_RETRY_ATTEMPTS=2
FOODMAP_REDISSON_RETRY_INTERVAL_MS=500

# RabbitMQ
RABBITMQ_DEFAULT_USER=foodmap
RABBITMQ_DEFAULT_PASS=change-me

# Kafka logging pipeline
KAFKA_IMAGE=bitnami/kafka:3.7
KAFKA_EXTERNAL_PORT=9094
KAFKA_LOG_RETENTION_HOURS=24
KAFKA_LOG_TOPIC_PARTITIONS=3
FLUENT_BIT_IMAGE=fluent/fluent-bit:3.1
LOG_KAFKA_BROKERS=kafka:9092
ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.15.3
ELASTICSEARCH_INIT_IMAGE=curlimages/curl:8.8.0
ELASTICSEARCH_HTTP_PORT=9200
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
LOGSTASH_IMAGE=docker.elastic.co/logstash/logstash:8.15.3
LOGSTASH_LOG_GROUP_ID=foodmap-logstash-elasticsearch-local
LOGSTASH_JAVA_OPTS=-Xms256m -Xmx256m
LOG_ELASTICSEARCH_URL=http://elasticsearch:9200
FLYWAY_IMAGE=flyway/flyway:10
LOG_SERVICE_API_ACCESS_CONSUMER_ENABLED=false
LOG_SERVICE_API_ACCESS_TOPIC=foodmap.logs.api-access
LOG_SERVICE_API_ACCESS_GROUP_ID=foodmap-log-service-api-access
LOG_SERVICE_API_ACCESS_RETENTION_DAYS=15
LOG_SERVICE_API_ACCESS_RETENTION_CLEANUP_ENABLED=false
LOG_SERVICE_API_ACCESS_RETENTION_CLEANUP_CRON=0 20 3 * * *
LOG_SERVICE_API_ACCESS_RETENTION_CLEANUP_ZONE=Asia/Shanghai
LOG_ARCHIVE_HOT_RETENTION_DAYS=7
LOG_ARCHIVE_SOURCE_INDEX_PATTERN=foodmap-logs-*
LOG_ARCHIVE_STORAGE_PROVIDER=OSS
LOG_ARCHIVE_BUCKET_NAME=foodmap-log-archive
LOG_ARCHIVE_OBJECT_PREFIX=logs/full
LOG_ARCHIVE_PLANNING_ENABLED=false
LOG_ARCHIVE_PLANNING_CRON=0 40 3 * * *
LOG_ARCHIVE_PLANNING_ZONE=Asia/Shanghai
LOG_ARCHIVE_EXECUTION_ENABLED=false
LOG_ARCHIVE_EXECUTION_CRON=0 */10 * * * *
LOG_ARCHIVE_EXECUTION_ZONE=Asia/Shanghai
LOG_ARCHIVE_STORAGE_UPLOAD_ENABLED=false
FOODMAP_SEARCH_ELASTICSEARCH_ENABLED=false
FOODMAP_SEARCH_ELASTICSEARCH_URL=http://elasticsearch:9200
FOODMAP_SEARCH_ELASTICSEARCH_CONNECT_TIMEOUT=3s
FOODMAP_SEARCH_ELASTICSEARCH_REQUEST_TIMEOUT=30s
FOODMAP_SEARCH_ELASTICSEARCH_USERNAME=
FOODMAP_SEARCH_ELASTICSEARCH_PASSWORD=
FOODMAP_SEARCH_ELASTICSEARCH_API_KEY=
LOG_ARCHIVE_ELASTICSEARCH_ENABLED=false
LOG_ARCHIVE_ELASTICSEARCH_URL=http://elasticsearch:9200
LOG_ARCHIVE_ELASTICSEARCH_PAGE_SIZE=1000
LOG_ARCHIVE_ELASTICSEARCH_MAX_PAGES=1000
LOG_ARCHIVE_ELASTICSEARCH_CONNECT_TIMEOUT=3s
LOG_ARCHIVE_ELASTICSEARCH_REQUEST_TIMEOUT=30s
LOG_ARCHIVE_ELASTICSEARCH_TIMESTAMP_FIELD=@timestamp
LOG_ARCHIVE_ELASTICSEARCH_USERNAME=
LOG_ARCHIVE_ELASTICSEARCH_PASSWORD=
LOG_ARCHIVE_ELASTICSEARCH_API_KEY=

# Nacos
NACOS_SERVER_ADDR=nacos:8848
NACOS_CONFIG_ENABLED=false
NACOS_CONFIG_GROUP=FOODMAP
NACOS_AUTH_ENABLE=true
NACOS_AUTH_TOKEN=change-me-at-least-32-chars
NACOS_AUTH_IDENTITY_KEY=foodmap
NACOS_AUTH_IDENTITY_VALUE=change-me

# JWT
JWT_SECRET=change-me-at-least-32-chars
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_USER_SERVICE_URL=
AUTH_USER_SERVICE_CONNECT_TIMEOUT_MS=3000
AUTH_USER_SERVICE_READ_TIMEOUT_MS=5000

# Aliyun OSS
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=foodmap-bucket
ALIYUN_OSS_ACCESS_KEY_ID=change-me
ALIYUN_OSS_ACCESS_KEY_SECRET=change-me

# Java memory
JAVA_OPTS=-Xms128m -Xmx256m -XX:+UseContainerSupport
